{
  "name": "m365-privacy-config",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "bierner.markdown-mermaid",
        "DavidAnson.vscode-markdownlint"
      ],
      "settings": {
        "python.testing.pytestEnabled": true
      }
    }
  },
  "postCreateCommand": "pip install --quiet pytest && python -m pytest -q || true"
}
